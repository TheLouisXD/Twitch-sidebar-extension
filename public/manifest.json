{
    "manifest_version": 3,
    "name": "Twitch live sidebar",
    "version": "1.0",
    "permissions": ["storage", "identity", "sidePanel"],
    "host_permissions": ["https://api.twitch.tv/*", "https://static-cdn.jtvnw.net/*"],
    "side_panel": {"default_path": "index.html"},
    "background": { "service_worker": "background.js"},
    "action": {}
}